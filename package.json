{
  "name": "@fuggetlenfe/components",
  "version": "0.1.0",
  "description": "Stencil web components – framework-agnostic, Figma-backed primitives",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "import": "./components/index.js"
    },
    "./components/*.js": {
      "types": "./components/*.d.ts",
      "import": "./components/*.js"
    }
  },
  "files": [
    "dist/",
    "loader/",
    "components/",
    "hydrate/"
  ],
  "scripts": {
    "build": "stencil build && node scripts/patch-custom-elements-types.mjs",
    "dev": "stencil build --dev --watch",
    "test": "stencil test --spec",
    "storybook": "storybook dev -p 6006 -c .storybook --ci",
    "build-storybook": "storybook build -c .storybook -o storybook-static"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@fuggetlenfe/tokens": "^0.1.0",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/web-components-vite": "^10.3.3",
    "@stencil/core": "^4.38.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "storybook": "^10.3.3"
  }
}
