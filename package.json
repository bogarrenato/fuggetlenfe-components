{
  "name": "@fuggetlenfe/components",
  "version": "0.2.0",
  "description": "Framework-independent Stencil web components for the Fuggetlenfe platform.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "import": "./components/index.js"
    },
    "./components/*.js": {
      "types": "./components/*.d.ts",
      "import": "./components/*.js"
    }
  },
  "files": [
    "dist/",
    "loader/",
    "components/",
    "hydrate/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bogarrenato/fuggetlenfe-components.git"
  },
  "bugs": {
    "url": "https://github.com/bogarrenato/fuggetlenfe-components/issues"
  },
  "homepage": "https://bogarrenato.github.io/fuggetlenfe-components/latest/",
  "scripts": {
    "build": "stencil build && node scripts/patch-custom-elements-types.mjs",
    "build-storybook": "storybook build -c .storybook -o storybook-static",
    "build:docs-site": "node scripts/build-docs-site.mjs",
    "dev": "stencil build --dev --watch",
    "pack:check": "npm pack --dry-run",
    "storybook": "storybook dev -p 6006 -c .storybook --ci",
    "test": "stencil test --spec --passWithNoTests"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@fuggetlenfe/tokens": "^0.2.0",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/web-components-vite": "^10.3.3",
    "@stencil/core": "^4.38.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "storybook": "^10.3.3"
  }
}
